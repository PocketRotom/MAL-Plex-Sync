# ──────────────────────────────────────────────────────────────────────────────
# MALSync Plex Bridge — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Port to listen on (default: 3000)
PORT=3000

# ── MAL ───────────────────────────────────────────────────────────────────────
# Register a client at https://myanimelist.net/apiconfig
# App type: "other", redirect URI: http://localhost:3000/auth/mal/callback
MAL_CLIENT_ID=your_mal_client_id_here

# ── Sync target ───────────────────────────────────────────────────────────────
# Which services to update.
SYNC_TARGET=mal

# ── Plex events to act on ─────────────────────────────────────────────────────
# media.scrobble fires automatically at ~90% watched.
# You can also add media.stop if you want to sync on pause/stop.
PLEX_EVENTS=media.scrobble

# ── Discord webhook ───────────────────────────────────────────────────────────
# When a title can't be matched automatically, a notification is sent here
# with a link to a resolution page where you can set the correct MAL ID.
# Leave empty to disable.
DISCORD_WEBHOOK_URL=

# The public base URL of this server — used to build the /resolve links sent
# to Discord. Change this if the server is behind a reverse proxy or ngrok.
BASE_URL=http://localhost:3000


